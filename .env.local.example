# Local development – matches the Docker container started by:
#   docker run --name pharma-jobs-dev \
#     -e POSTGRES_DB=pharma_jobs \
#     -e POSTGRES_USER=pharma \
#     -e POSTGRES_PASSWORD=pharma \
#     -p 5433:5432 -d postgres:16
#
# If port 5432 is already in use by another container, use 5433 (as above).
# Adjust DB_PORT below to match whichever port you chose.
#
# Copy this file to .env for local dev:
#   cp .env.local.example .env
DB_HOST=localhost
DB_PORT=5433
DB_NAME=pharma_jobs
DB_USER=pharma
DB_PASSWORD=pharma
