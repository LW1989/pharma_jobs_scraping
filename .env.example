# Copy this file to .env and fill in your values

# PostgreSQL (Hetzner production)
DB_HOST=<hetzner_ip>
DB_PORT=5432
DB_NAME=pharma_jobs
DB_USER=<db_user>
DB_PASSWORD=<db_password>

# OpenAI — required for run_evaluator.py
OPENAI_API_KEY=sk-...
# Recommended: gpt-5-mini (best quality/cost ratio as of March 2026)
# Alternatives: gpt-5-nano (cheapest), gpt-4.1-mini (solid mid-tier)
OPENAI_MODEL=gpt-5-mini
