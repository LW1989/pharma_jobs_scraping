# Copy this file to .env and fill in your values

# PostgreSQL (Hetzner production)
DB_HOST=<hetzner_ip>
DB_PORT=5432
DB_NAME=pharma_jobs
DB_USER=<db_user>
DB_PASSWORD=<db_password>

# OpenAI — required for run_evaluator.py
OPENAI_API_KEY=sk-...
# Recommended: gpt-5-mini (best quality/cost ratio as of March 2026)
# Alternatives: gpt-5-nano (cheapest), gpt-4.1-mini (solid mid-tier)
OPENAI_MODEL=gpt-5-mini

# Email — required for run_reporter.py
# Use a Gmail App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_16char_app_password
REPORT_TO=recipient@example.com   # comma-separated for multiple recipients

# Telegram — required for run_reporter.py
# Create a bot via @BotFather, then get the chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-1001234567890